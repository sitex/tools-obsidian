# =============================================================================
# LibreChat + MCP — пример .env
# Скопировать в .env и заполнить реальными значениями
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- MongoDB (используется встроенный контейнер, URI менять не нужно) ---
MONGO_URI=mongodb://mongodb:27017/LibreChat

# --- Meilisearch ---
# Генерировать: openssl rand -hex 32
MEILI_MASTER_KEY=change-me-generate-with-openssl-rand-hex-32

# --- JWT ---
# Генерировать: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-hex-32

# --- Регистрация ---
# false = только admin может создавать аккаунты
ALLOW_REGISTRATION=false

# --- Session ---
# Время жизни access token в мс (15 минут по умолчанию)
SESSION_EXPIRY=900000
# Время жизни refresh token в мс (7 дней по умолчанию)
REFRESH_TOKEN_EXPIRY=604800000

# --- Опционально: домен для cookies ---
# DOMAIN=librechat.tail1234.ts.net
